{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "modarbot",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Open ModarBot Watchtower",
        "description": "Create or open the Watchtower post for this subreddit",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/watchtower-open"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostSubmit": "/internal/triggers/on-post-submit",
    "onCommentSubmit": "/internal/triggers/on-comment-submit",
    "onPostReport": "/internal/triggers/on-post-report",
    "onCommentReport": "/internal/triggers/on-comment-report",
    "onModAction": "/internal/triggers/on-mod-action"
  },
  "scheduler": {
    "tasks": {
      "vote-snapshot": {
        "endpoint": "/internal/scheduler/vote-snapshot",
        "cron": "*/2 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  }
}
